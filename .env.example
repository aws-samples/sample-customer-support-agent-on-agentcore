# XXXX Agent Environment Configuration
# Copy this file to .env and fill in the values

# AWS Bedrock Configuration (required)
CLAUDE_CODE_USE_BEDROCK=1

# AWS Credentials (if not using AWS CLI profile or IAM role)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-west-2

# AgentCore Memory (run 'python scripts/setup_memory.py' to create)
# Leave empty to disable memory features
MEMORY_ID=

# Remote MCP Server Configuration
MCP_SERVER_URL=<MCP_SERVER_URL>
MCP_AUTH_TOKEN=

# Model Configuration (optional)
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
