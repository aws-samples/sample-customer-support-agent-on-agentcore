# AgentCore Runtime Deployment Configuration
# Copy this file to .env.runtime and fill in the values

# AgentCore Gateway ID (required for deployment)
AGENTCORE_GATEWAY_ID=

# IAM Execution Role ARN (optional, uses default if not set)
EXECUTION_ROLE_ARN=

# Cognito OAuth Configuration (if using OAuth authentication)
# COGNITO_DOMAIN=
# COGNITO_CLIENT_ID=
# COGNITO_CLIENT_SECRET=
# COGNITO_DISCOVERY_URL=
